{
  "name": "@mcptoolshop/style-dataset-lab",
  "version": "2.1.0",
  "description": "Visual canon and dataset production pipeline — snapshots, splits, versioned exports, eval packs, and canon-bound curation for any image production domain",
  "type": "module",
  "bin": {
    "sdlab": "./bin/sdlab.js"
  },
  "scripts": {
    "generate": "node scripts/generate.js",
    "curate": "node scripts/curate.js",
    "compare": "node scripts/compare.js",
    "canon-bind": "node scripts/canon-bind.js",
    "painterly": "node scripts/painterly.js",
    "generate:identity": "node scripts/generate-identity.js",
    "export": "echo 'Usage: repo-dataset visual generate ./projects/<project> --format trl'",
    "inspect": "echo 'Usage: repo-dataset visual inspect ./projects/<project>'"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "templates/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "dataset",
    "computer-vision",
    "training-data",
    "image-dataset",
    "evaluation",
    "curation",
    "canon",
    "visual-development",
    "concept-art",
    "style-guide",
    "lora",
    "multimodal",
    "comfyui"
  ],
  "homepage": "https://mcp-tool-shop-org.github.io/style-dataset-lab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/style-dataset-lab.git"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "mcp-tool-shop",
  "license": "MIT"
}

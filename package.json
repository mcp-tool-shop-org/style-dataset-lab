{
  "name": "@mcptoolshop/style-dataset-lab",
  "version": "3.1.0",
  "description": "Canon-aligned dataset production and generation workbench — define visual rules, build versioned training data, compile production briefs, run local workflows, batch-produce, select winners, and re-ingest into your corpus",
  "type": "module",
  "bin": {
    "sdlab": "./bin/sdlab.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "coverage": "c8 npm test",
    "verify": "node bin/sdlab.js --help && node bin/sdlab.js project doctor --project star-freight",
    "generate": "node scripts/generate.js",
    "curate": "node scripts/curate.js",
    "compare": "node scripts/compare.js",
    "canon-bind": "node scripts/canon-bind.js",
    "painterly": "node scripts/painterly.js",
    "generate:identity": "node scripts/generate-identity.js"
  },
  "c8": {
    "include": ["lib/**/*.js"],
    "exclude": [
      "tests/**",
      "scripts/**",
      "site/**",
      "projects/**",
      "templates/**",
      "**/*.test.js"
    ],
    "reporter": ["text", "lcov", "text-summary"],
    "report-dir": "coverage",
    "all": true
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "!scripts/bulk-curate-*.js",
    "!scripts/curate-wave*.js",
    "!scripts/migrate-records.js",
    "templates/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "keywords": [
    "dataset",
    "computer-vision",
    "training-data",
    "image-dataset",
    "evaluation",
    "curation",
    "canon",
    "visual-development",
    "concept-art",
    "style-guide",
    "lora",
    "multimodal",
    "comfyui",
    "generation-workflow",
    "batch-production",
    "reintegration"
  ],
  "homepage": "https://mcp-tool-shop-org.github.io/style-dataset-lab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/style-dataset-lab.git"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "devDependencies": {
    "c8": "^10.1.3"
  }
}

---
/**
 * SiteLayout — local wrapper around @mcptoolshop/site-theme's BaseLayout.
 *
 * The upstream BaseLayout does not currently accept Open Graph / Twitter Card
 * meta props, so we render our own <head> + shell here with the same visual
 * structure and inject the social-preview tags before the <title>. Handbook
 * pages are generated by Starlight and inherit the site-wide <title> +
 * <description> plus these OG tags via astro.config site/base.
 */
interface Props {
  title: string;
  description: string;
  logoBadge: string;
  brandName: string;
  nav?: { href: string; label: string }[];
  repoUrl: string;
  npmUrl?: string;
  /** Footer text — accepts raw HTML. Sanitize if sourced from user input. */
  footerText: string;
  /** Absolute URL of the Open Graph preview image (1200x630 recommended). */
  ogImage?: string;
  /** Canonical URL for this page (used by og:url). */
  ogUrl?: string;
}

const {
  title,
  description,
  logoBadge,
  brandName,
  nav = [],
  repoUrl,
  npmUrl,
  footerText,
  ogImage,
  ogUrl,
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    {/* Open Graph / Facebook / Slack / Discord / LinkedIn */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content={brandName} />

    {/* Twitter / X */}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-surface text-heading antialiased">
    <div class="mx-auto max-w-6xl px-4">
      <header class="flex items-center justify-between py-6">
        <a href={base} class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-surface-strong">
            {logoBadge}
          </span>
          <span>{brandName}</span>
        </a>

        <nav aria-label="Main navigation" class="hidden items-center gap-6 text-sm text-muted md:flex">
          {nav.map((item: { href: string; label: string }) => (
            <a href={item.href} class="hover:text-heading">{item.label}</a>
          ))}
        </nav>

        <div class="flex items-center gap-3">
          {npmUrl && (
            <a
              class="hidden rounded-xl border border-edge px-4 py-2 text-sm text-body hover:bg-surface-raised md:inline-flex"
              href={npmUrl}
              target="_blank"
              rel="noreferrer"
            >
              npm
            </a>
          )}
          <a
            class="hidden rounded-xl bg-action px-4 py-2 text-sm font-medium text-action-text hover:bg-action-hover md:inline-flex"
            href={repoUrl}
            target="_blank"
            rel="noreferrer"
          >
            GitHub
          </a>

          {/*
           * Mobile-only nav toggle. Uses <details>/<summary> so the menu works
           * without JavaScript — collapses by default, expands to a full-width
           * drawer underneath the header. The list-marker is hidden via CSS.
           */}
          <details class="relative md:hidden" id="mobile-nav">
            <summary
              aria-label="Toggle navigation menu"
              class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-xl border border-edge text-body hover:bg-surface-raised"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
              </svg>
            </summary>
            <div
              class="absolute right-0 top-12 z-30 w-56 rounded-xl border border-edge bg-surface-strong p-3 shadow-xl"
              role="menu"
            >
              <nav aria-label="Mobile navigation" class="flex flex-col gap-1 text-sm">
                {nav.map((item: { href: string; label: string }) => (
                  <a
                    href={item.href}
                    role="menuitem"
                    class="rounded-lg px-3 py-2 text-body hover:bg-surface-raised hover:text-heading"
                  >
                    {item.label}
                  </a>
                ))}
                <div class="my-2 border-t border-edge-subtle" />
                {npmUrl && (
                  <a
                    href={npmUrl}
                    target="_blank"
                    rel="noreferrer"
                    role="menuitem"
                    class="rounded-lg px-3 py-2 text-body hover:bg-surface-raised hover:text-heading"
                  >
                    npm
                  </a>
                )}
                <a
                  href={repoUrl}
                  target="_blank"
                  rel="noreferrer"
                  role="menuitem"
                  class="rounded-lg bg-action px-3 py-2 font-medium text-action-text hover:bg-action-hover"
                >
                  GitHub
                </a>
              </nav>
            </div>
          </details>
        </div>
      </header>

      <main class="pb-24">
        <slot />
      </main>

      <footer class="border-t border-edge-subtle py-10 text-sm text-dim">
        <div class="flex flex-col justify-between gap-4 md:flex-row">
          <p set:html={footerText} />
          <nav aria-label="Footer links" class="flex gap-4">
            {npmUrl && (
              <a class="hover:text-body" href={npmUrl} target="_blank" rel="noreferrer">npm</a>
            )}
            <a class="hover:text-body" href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
            <a class="hover:text-body" href="https://opensource.org/license/mit/" target="_blank" rel="noreferrer">License</a>
          </nav>
        </div>
      </footer>
    </div>

    <style is:global>
      /* Hide the default disclosure triangle on the mobile-nav <summary>
       * so the hamburger SVG stands alone. */
      details#mobile-nav > summary { list-style: none; }
      details#mobile-nav > summary::-webkit-details-marker { display: none; }
    </style>
  </body>
</html>

{
  "workflow_id": "variant-pack",
  "label": "Vehicle Variant Pack",
  "description": "Generate controlled design variants for a named vehicle subject.",
  "lane_id": "exterior",
  "subject_mode": "required",
  "output_mode": "variant_pack",
  "output_count": 4,
  "required_reference_roles": ["anchor"],

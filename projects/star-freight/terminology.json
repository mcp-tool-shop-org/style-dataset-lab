      "id_patterns": ["^k_", "^k\\d+_"],
      "prompt_patterns": ["arthropod", "keth", "chitin", "antennae"],
      "construction": {
        "CLO-002": "Grown on wearer or harvested from communal bio-stocks"
      }
    },
    "veshan": {
      "material": "Forged (hammered, riveted, layered)",
      "shapes": "Triangles, chevrons, sharp angles",

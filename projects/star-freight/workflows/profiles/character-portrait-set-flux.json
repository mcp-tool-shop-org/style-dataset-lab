{
  "workflow_id": "character-portrait-set-flux",
  "label": "Character Portrait Set (Flux)",
  "description": "Generate a focused portrait candidate pack for a named subject, targeting FLUX.1-dev. Intended local checkpoint: flux1-dev-fp8.safetensors (fp8 quantization fits 16GB VRAM on the RTX 5080). Runtime defaults follow Flux-dev recommended ranges (distilled model, low CFG, euler sampler).",
  "lane_id": "costume",
  "subject_mode": "required",
  "output_mode": "portrait_set",
  "output_count": 4,
  "required_reference_roles": ["anchor", "supporting"],
  "preferred_reference_tags": ["portrait", "approved"],
  "prompt_strategy": {
    "style_prefix": [
      "project-canon aligned portrait concept art",
      "high fidelity facial continuity",
      "clean readable silhouette"
    ],
    "structure": "style_prefix, subject_identity, lane_goal, canon_focus, controlled_variation",
    "must_include": [
      "subject identity",
      "faction or project read",
      "costume logic",
      "palette fidelity"
    ],
    "optional_blocks": [
      "lighting note",
      "gesture note",
      "surface wear note"
    ]
  },
  "negative_strategy": {
    "must_avoid": [
      "off-model face",
      "extra accessories",
      "wrong faction materials",
      "ornamental drift",
      "generic fantasy styling"
    ],
    "lane_specific_avoid": [
      "cropped silhouette ambiguity",
      "muddy facial read"
    ],
    "subject_specific_avoid": []
  },
  "canon_focus": [
    "silhouette",
    "costume_logic",
    "palette",
    "faction_read",
    "gesture"
  ],
  "drift_guards": [
    "preserve face structure",
    "preserve age read",
    "preserve canonical materials",
    "do not add non-canon ornament"
  ],
  "runtime_defaults": {
    "adapter_target": "comfyui",
    "checkpoint": "flux1-dev-fp8.safetensors",
    "width": 1024,
    "height": 1024,
    "steps": 24,
    "cfg": 1.0,
    "sampler": "euler",
    "scheduler": "simple",
    "seed_mode": "increment"
  }
}

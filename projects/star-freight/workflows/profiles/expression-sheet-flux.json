{
  "workflow_id": "expression-sheet-flux",
  "label": "Expression Sheet (Flux)",
  "description": "Produce multiple expressions while preserving subject identity, targeting FLUX.1-dev. Flux's T5 text encoder holds subject identity across expression variation much better than SDXL's CLIP, so this workflow benefits strongly from the Flux migration. Intended local checkpoint: flux1-dev-fp8.safetensors.",
  "lane_id": "costume",
  "subject_mode": "required",
  "output_mode": "expression_sheet",
  "output_count": 6,
  "required_reference_roles": ["anchor"],
  "preferred_reference_tags": ["portrait", "expression", "approved"],
  "prompt_strategy": {
    "style_prefix": [
      "character expression sheet concept art",
      "consistent identity across expressions",
      "head and shoulders framing"
    ],
    "structure": "style_prefix, subject_identity, canon_focus, controlled_variation",
    "must_include": [
      "subject identity",
      "facial expression variety",
      "consistent costume and hair"
    ],
    "optional_blocks": [
      "lighting note",
      "emotion label"
    ]
  },
  "negative_strategy": {
    "must_avoid": [
      "face structure drift",
      "hairstyle drift",
      "costume mutation",
      "expression exaggeration breaking identity",
      "age drift"
    ],
    "lane_specific_avoid": [
      "full body composition",
      "background complexity"
    ],
    "subject_specific_avoid": []
  },
  "canon_focus": [
    "anatomy",
    "gesture",
    "costume_logic",
    "palette"
  ],
  "drift_guards": [
    "face structure must remain identical across all outputs",
    "hairstyle must not change",
    "costume must not mutate between expressions",
    "expression exaggeration must not break identity read"
  ],
  "runtime_defaults": {
    "adapter_target": "comfyui",
    "checkpoint": "flux1-dev-fp8.safetensors",
    "width": 1024,
    "height": 1024,
    "steps": 24,
    "cfg": 1.0,
    "sampler": "euler",
    "scheduler": "simple",
    "seed_mode": "increment"
  }
}
